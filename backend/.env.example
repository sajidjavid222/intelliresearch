# Copy to .env and fill in what you have. Everything has safe defaults.

# --- Database (SQLite by default; switch to Postgres for production) ---
DATABASE_URL=sqlite+aiosqlite:///./researchpilot.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/researchpilot

# --- App ---
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_ORIGIN=http://localhost:3000

# --- LLM (optional but unlocks AI synthesis: reviews, gaps, proposals) ---
LLM_PROVIDER=auto            # auto | openai | anthropic | gemini | none
# Gemini free key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# gemini-3.1-flash-lite has the highest free-tier quota (500 req/day vs 20).
# On a 429, the app auto-falls back across other free models, so set the
# highest-capacity one here and let the chain handle spillover.
# GEMINI_MODEL=gemini-3.1-flash-lite
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Google Scholar author profiles (via `scholarly`) ---
# Best-effort: Google Scholar blocks scrapers, so this is often unavailable
# from servers and falls back to OpenAlex. Set SCHOLAR_ENABLED=false to skip it.
# SCHOLAR_ENABLED=true
# SCHOLAR_TIMEOUT_SECONDS=12
# SCHOLAR_USE_PROXY=false   # try free proxies to dodge blocks (slow, unreliable)

# --- Data source keys (all optional; sources work key-free at lower rate limits) ---
# SEMANTIC_SCHOLAR_API_KEY=
# GITHUB_TOKEN=ghp_...
# HUGGINGFACE_TOKEN=hf_...
# CORE_API_KEY=        # free at https://core.ac.uk/services/api — makes CORE reliable/fast
# Note: PubMed, DOAJ, DBLP, arXiv, OpenAlex, Crossref need no key.

# --- Google OAuth (optional) ---
# Your OAuth client ID from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=

# --- Infra (optional) ---
# Cache uses Redis when REDIS_URL is reachable, else an in-memory fallback.
REDIS_URL=redis://localhost:6379/0
# QDRANT_URL=http://localhost:6333

# --- Caching of upstream source API calls ---
CACHE_ENABLED=true
CACHE_TTL_SECONDS=600   # how long to reuse a cached upstream response
